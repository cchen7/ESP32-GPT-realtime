# Copy to .env and fill in your values. Never commit .env.

# === Service principal (DefaultAzureCredential picks these up) ===
# REQUIRED on hosts without `az` cli (e.g. the Debian bridge).
AZURE_TENANT_ID=<tenant-guid>
AZURE_CLIENT_ID=<app-client-id>
AZURE_CLIENT_SECRET=<client-secret>

# === Azure resource endpoints (REQUIRED) ===
# AZURE_OPENAI_ENDPOINT: host of the AIServices / Azure OpenAI resource.
#   No scheme, no path. e.g.  my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=<your-aiservices-host>
AZURE_OPENAI_DEPLOYMENT=gpt-realtime-2

# === Foundry Responses endpoint for Bing grounding ===
# Full URL up to (and including) /api/projects/<project-name>.
FOUNDRY_PROJECT_ENDPOINT=https://<your-host>.services.ai.azure.com/api/projects/<your-project>
GROUNDING_DEPLOYMENT=gpt-4.1-mini

# Full ARM resource ID of the project's "Grounding with Bing Search" connection.
BING_CONNECTION_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<bing-connection>

# === Optional overrides (defaults shown) ===
# REALTIME_VOICE=alloy
# BRIDGE_WS_HOST=0.0.0.0
# BRIDGE_WS_PORT=8765
# DEVICE_SAMPLE_RATE=16000
# ENABLE_WEB_SEARCH=1
# BING_MARKET=zh-CN
# BING_FRESHNESS=Day
# BING_COUNT=5
